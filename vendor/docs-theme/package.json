{
  "name": "mkdocs-code-siemens-code-docs-theme",
  "description": "The official code.siemens.io theme for MkDocs.",
  "version": "7.8.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "git@code.siemens.com:code-ops/docs-theme.git"
  },
  "author": {
    "name": "Siemens AG",
    "email": "info@siemens.com"
  },
  "homepage": "https://code.siemens.com/code-ops/docs-theme",
  "bugs": "https://code.siemens.com/code-ops/docs-theme/issues",
  "scarfSettings": {
    "enabled": false
  },
  "scripts": {
    "src:lint:js": "eslint cypress *.js",
    "src:lint:py": "uv run black src && uv run isort src && uv run mypy src && uv run flake8 src",
    "src:lint:py:check": "uv run black --check src && uv run isort src && uv run mypy src && uv run flake8 src",
    "src:lint:scss": "stylelint \"./src/templates/assets/stylesheets/**/*.scss\" --config=./.stylelintrc",
    "src:compile": "sass --style compressed -I node_modules/mkdocs-material/src/templates/assets/stylesheets -I node_modules/material-shadows -I node_modules/@simpl/element-base-theme/src/variables/siemens-brand -I node_modules src/templates/assets/stylesheets/main.scss mkdocs_siemens/templates/assets/stylesheets/code-main-sass.css",
    "src:postcss": "yarn postcss mkdocs_siemens/templates/assets/stylesheets/code-main-sass.css -o mkdocs_siemens/templates/assets/stylesheets/code-main.css && rm mkdocs_siemens/templates/assets/stylesheets/code-main-sass.*",
    "src:hash": "sed -i'.bak' \"s/code-main.css/$(cat manifest.json | jq -r '.[]')/g\" mkdocs_siemens/templates/base-siemens.html",
    "dist:cpy:html": "html-minifier --input-dir src/ --output-dir mkdocs_siemens/ --file-ext html --keep-closing-slash --remove-comments",
    "dist:cpy:vendor": "cpy --flat node_modules/swagger-ui-dist/oauth2-redirect.html mkdocs_siemens/templates/ && cpy --flat node_modules/swagger-ui-dist/swagger-ui-bundle.js mkdocs_siemens/templates/assets/javascripts/ && cpy --flat node_modules/@asyncapi/react-component/browser/standalone/index.js mkdocs_siemens/templates/assets/javascripts/asyncapi-react-component/ && cpy --flat node_modules/@simpl/element-icons/dist/icons/* mkdocs_siemens/templates/.icons/siemens/element",
    "dist:cpy:src": "cpy . '!**/*.html' '!**/*.scss' '../mkdocs_siemens' --dot --cwd=src",
    "dist:cpy:sbom": "mkdir -p mkdocs_siemens/templates/.data/ && yarn cyclonedx-node --include-license-text --output mkdocs_siemens/templates/.data/cyclonedx-js.json",
    "dist:setup": "yarn dist:clean && yarn src:lint:js && yarn src:lint:py:check && yarn src:lint:scss && yarn src:compile && yarn src:postcss && yarn dist:cpy:src && yarn dist:cpy:vendor && yarn dist:cpy:html && yarn src:hash && yarn dist:cpy:sbom",
    "dist:build": "uv build -o dist/",
    "dist:local": "yarn dist:setup && yarn dist:build",
    "dist:clean": "git clean -ffdx mkdocs_siemens/ dist/ mkdocs_siemens.egg-info/",
    "e2e:start:all-features": "cd cypress/resources && uv run mkdocs serve",
    "e2e:start:minimal": "cd cypress/resources && uv run mkdocs serve --config-file=mkdocs-minimal.yml --dev-addr=127.0.0.1:8001",
    "e2e:start": "yarn e2e:start:all-features & yarn e2e:start:minimal",
    "e2e:open": "cypress open",
    "e2e:open:minimal": "CYPRESS_SUITE=minimal cypress open",
    "e2e:run": "cypress run --browser $CYPRESS_BROWSER",
    "e2e:run:chrome": "CYPRESS_BROWSER=chrome yarn e2e:run",
    "e2e:run:firefox": "CYPRESS_BROWSER=firefox yarn e2e:run",
    "e2e:run:minimal": "CYPRESS_SUITE=minimal yarn e2e:run",
    "e2e:run:minimal:chrome": "CYPRESS_BROWSER=chrome yarn e2e:run:minimal",
    "e2e:run:minimal:firefox": "CYPRESS_BROWSER=firefox yarn e2e:run:minimal",
    "e2e:docker:chrome": "CYPRESS_BROWSER=chrome ./scripts/test.sh run",
    "e2e:docker:firefox": "CYPRESS_BROWSER=firefox ./scripts/test.sh run",
    "e2e:docker:minimal:chrome": "CYPRESS_SUITE=minimal ./scripts/test.sh run",
    "e2e:docker:minimal:firefox": "CYPRESS_SUITE=minimal CYPRESS_BROWSER=firefox ./scripts/test.sh run",
    "e2e:docker": "yarn e2e:docker:chrome && yarn e2e:docker:firefox && yarn e2e:docker:minimal:chrome && yarn e2e:docker:minimal:firefox",
    "e2e:clean": "git clean -ffdx cypress/resources/"
  },
  "devDependencies": {
    "@cyclonedx/bom": "3.10.6",
    "@eslint/js": "^10.0.1",
    "cpy-cli": "^7.0.0",
    "cypress": "15.13.0",
    "cypress-image-snapshot": "^4.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-cypress": "^6.1.0",
    "html-minifier": "^4.0.0",
    "material-shadows": "^3.0.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-dir-pseudo-class": "^10.0.0",
    "postcss-hash": "^3.0.0",
    "postcss-logical": "5.0.4",
    "sass": "^1.97.3",
    "start-server-and-test": "^3.0.0",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.0.0",
    "stylelint-scss": "^7.0.0"
  },
  "dependencies": {
    "@asyncapi/react-component": "2.6.4",
    "@siemens/element-theme": "^49.0.0",
    "@simpl/brand": "^2.3.0",
    "@simpl/element-icons": "^1.32.0",
    "mkdocs-material": "squidfunk/mkdocs-material#9.7.6",
    "swagger-ui-dist": "5.32.0"
  }
}
